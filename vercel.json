{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -w run vercel-build",
  "outputDirectory": "dist",
  "framework": null,
  "nodeVersion": "20.x",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.agroloopci.ci/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
